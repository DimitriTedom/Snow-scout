# YouTube Data API v3 — comma-separated for quota rotation
YOUTUBE_API_KEYS=

# OpenRouter — free models, comma-separated keys + models for rotation
# Comma-separated for rotation on rate limits
OPENROUTER_API_KEYS=
OPENROUTER_REMIX_MODELS=google/gemma-2-9b-it:free,meta-llama/llama-3.2-3b-instruct:free,qwen/qwen-2-7b-instruct:free
SCOUT_REMIX_PROVIDER=openrouter

# prisma (default) | file
SCOUT_STORE_ADAPTER=prisma

# file (default) | supabase — API response cache (search, comments, brief build)
SCOUT_CACHE_ADAPTER=file
SCOUT_CACHE_DIR=D:/SnowDev/Videos/Youtube/CRAVE & CONQUER/.scout-cache
SCOUT_CACHE_BUCKET=scout-cache
SCOUT_BRIEFS_BUCKET=scout-briefs

PORT=3002

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — Storage uploads (briefs + optional API cache). Never expose in browser.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=